@model FoodOrderingLab2.ViewModels.OrderDetailViewModel
@{ ViewData["Title"] = "Order #" + Model.Order.OrderId; }

<section class="detail-page">
    <div class="detail-card detail-surface">
        <div class="detail-hero">
            <div>
                <span class="detail-eyebrow">Order details</span>
                <h1>Narudžba #@Model.Order.OrderId</h1>
                <p class="detail-lead">Kreirana @Model.Order.OrderDate.ToString("d.M.yyyy 'u' H:mm")</p>
            </div>
            <div class="price-panel">
                <span>Total</span>
                <strong>@Model.Order.TotalPrice.ToString("F2") EUR</strong>
                <small class="status-badge">@Model.Order.Status</small>
            </div>
        </div>

        <div class="detail-two-col detail-section">
            <div class="info-panel">
                <span class="detail-eyebrow">Customer</span>
                <h2>@Model.Customer?.FullName</h2>
                <p>@Model.Customer?.Email</p>
                <p>@Model.Customer?.Phone</p>
                <p>@Model.Customer?.Address</p>
            </div>
            <div class="info-panel">
                <span class="detail-eyebrow">Restaurant</span>
                <h2>@Model.Restaurant?.Name</h2>
                <p>@Model.Restaurant?.Address</p>
                <p>@Model.Restaurant?.Email</p>
                <p>@Model.Restaurant?.Phone</p>
            </div>
        </div>

        <div class="detail-section">
            <div class="section-heading">
                <div>
                    <span class="detail-eyebrow">Order contents</span>
                    <h2>Stavke narudžbe</h2>
                </div>
                <span class="item-count">@Model.OrderItems.Sum(x => x.Quantity) items</span>
            </div>
            <div class="order-item-list">
                @foreach (var item in Model.OrderItems)
                {
                    <div class="order-detail-item">
                        <div>
                            <strong>@item.MenuItem?.Name</strong>
                            @if (!string.IsNullOrWhiteSpace(item.SpecialRequests))
                            {
                                <small>@item.SpecialRequests</small>
                            }
                        </div>
                        <span>@item.Quantity × @item.UnitPrice.ToString("F2") EUR</span>
                        <strong>@item.TotalItemPrice.ToString("F2") EUR</strong>
                    </div>
                }
            </div>
        </div>

        <div class="detail-action action-bar">
            <a class="btn btn-secondary" asp-controller="Order" asp-action="Index">Back to orders</a>
            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <a class="btn btn-outline" asp-controller="Order" asp-action="Edit" asp-route-id="@Model.Order.OrderId">Edit order</a>
            }
        </div>
    </div>
</section>
