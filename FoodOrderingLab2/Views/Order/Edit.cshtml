@model FoodOrderingLab2.ViewModels.OrderCreateViewModel

@{
    ViewData["Title"] = "Uredi narudžbu";
    var customer = ViewBag.Customer as FoodOrderingLab2.Models.Customer;
    var restaurant = ViewBag.Restaurant as FoodOrderingLab2.Models.Restaurant;
    var orderId = ViewBag.OrderId as int?;
}

<div class="page-header page-header-center">
    <h1>Uredi narudžbu #@orderId</h1>
</div>

<div class="form-container">
    <form method="post" class="order-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="OrderId" value="@orderId" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="form-group">
            <label for="customer-autocomplete">Kupac</label>
            @{
                ViewData["name"] = "CustomerId";
                ViewData["id"] = "customer-autocomplete";
                ViewData["apiUrl"] = "/kupci/search";
                ViewData["placeholder"] = "Odaberi kupca";
                ViewData["required"] = true;
                ViewData["selectedId"] = Model.CustomerId.ToString();
                ViewData["selectedText"] = customer?.FullName ?? "Nepoznat kupac";
            }
            <partial name="_AutocompletePartial" />
            <span asp-validation-for="CustomerId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label for="restaurant-autocomplete">Restoran</label>
            @{
                ViewData["name"] = "RestaurantId";
                ViewData["id"] = "restaurant-autocomplete";
                ViewData["apiUrl"] = "/restorani/search";
                ViewData["placeholder"] = "Odaberi restoran";
                ViewData["required"] = true;
                ViewData["selectedId"] = Model.RestaurantId.ToString();
                ViewData["selectedText"] = restaurant?.Name ?? "Nepoznat restoran";
            }
            <partial name="_AutocompletePartial" />
            <span asp-validation-for="RestaurantId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label for="order-date">Datum narudžbe</label>
            @{
                ViewData["name"] = "OrderDate";
                ViewData["date"] = Model.OrderDate;
            }
            <partial name="_DateTimePartial" />
            <span asp-validation-for="OrderDate" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label for="status">Status</label>
            <select name="Status" id="status" class="form-control">
@{
    var statusVal = (int)Model.Status;
    if (statusVal == 1) { <text><option value="1" selected>Na čekanju</option></text> } else { <text><option value="1">Na čekanju</option></text> }
    if (statusVal == 2) { <text><option value="2" selected>Potvrđeno</option></text> } else { <text><option value="2">Potvrđeno</option></text> }
    if (statusVal == 3) { <text><option value="3" selected>U pripremi</option></text> } else { <text><option value="3">U pripremi</option></text> }
    if (statusVal == 4) { <text><option value="4" selected>Spremno za preuzimanje</option></text> } else { <text><option value="4">Spremno za preuzimanje</option></text> }
    if (statusVal == 5) { <text><option value="5" selected>Dostavljeno</option></text> } else { <text><option value="5">Dostavljeno</option></text> }
    if (statusVal == 6) { <text><option value="6" selected>Otkazano</option></text> } else { <text><option value="6">Otkazano</option></text> }
}
            </select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>

        <h3>Stavke narudžbe</h3>
        <table id="order-items" class="table">
            <thead>
                <tr><th>Artikl</th><th>Količina</th><th>Napomena</th><th></th></tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Items.Count; i++) {
                    <tr>
                        <td data-label="Artikl">
                            <select class="form-control autocomplete-select item-menu" data-api="/meni/search" name="Items[@i].MenuItemId" style="width:100%">
                                @{ var menuNames = ViewBag.MenuItemNames as Dictionary<int, string>; }
                                <option value="@Model.Items[i].MenuItemId" selected>
                                    @(menuNames != null && menuNames.ContainsKey(Model.Items[i].MenuItemId) ? menuNames[Model.Items[i].MenuItemId] : ("#" + Model.Items[i].MenuItemId))
                                </option>
                            </select>
                        </td>
                        <td data-label="Količina"><input type="number" min="1" value="@Model.Items[i].Quantity" class="form-control" name="Items[@i].Quantity" /></td>
                        <td data-label="Napomena"><input type="text" class="form-control" value="@Model.Items[i].SpecialRequests" name="Items[@i].SpecialRequests" maxlength="500" /></td>
                        <td data-label="Akcija"><button type="button" class="btn btn-danger btn-small remove-item">Ukloni</button></td>
                    </tr>
                }

                <tr class="order-item-row" style="display:none;">
                    <td data-label="Artikl">
                        <select class="form-control autocomplete-select item-menu" data-api="/meni/search" data-placeholder="Odaberi artikl" data-skip-autocomplete="true" name="Items[__index__].MenuItemId" style="width:100%"><option value=""></option></select>
                    </td>
                    <td data-label="Količina"><input type="number" min="1" value="1" class="form-control" name="Items[__index__].Quantity" /></td>
                    <td data-label="Napomena"><input type="text" class="form-control" name="Items[__index__].SpecialRequests" maxlength="500" /></td>
                    <td data-label="Akcija"><button type="button" class="btn btn-danger btn-small remove-item">Ukloni</button></td>
                </tr>
            </tbody>
        </table>
        <div style="margin-bottom: 1rem;"><button type="button" id="add-item" class="btn btn-secondary">Dodaj stavku</button></div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Spremi promjene</button>
            <a href="@Url.Action("Details", new { id = orderId })" class="btn btn-secondary">Odustani</a>
        </div>
    </form>

    <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid #444;">
        <form method="post" action="@Url.Action("Delete", new { id = orderId })" style="display:inline;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger" onclick="return confirm('Jeste sigurni da želite obrisati ovu narudžbu?');">Obriši narudžbu</button>
        </form>
    </div>
</div>

@* Menu item names are provided via ViewBag.MenuItemNames *@

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function getRestaurantId(){
            return $('#restaurant-autocomplete').val() || '@Model.RestaurantId';
        }
        (function($){
            $(function(){
                var idx = @Model.Items.Count;

                function getSelectedRestaurantId(){
                    return $('#restaurant-autocomplete').val();
                }

                function initMenuItemSelect($s){

                    if ($s.hasClass('select2-hidden-accessible')) {
                        $s.select2('destroy');
                    }

                    var placeholder = $s.data('placeholder') || 'Odaberi artikl';

                    var existingValue = $s.val();
                    var existingText = $s.find('option').first().text();

                    if ($s.find('option[value=""]').length === 0) {
                        $s.prepend('<option value=""></option>');
                    }

                    $s.prop('disabled', false);

                    $s.select2({
                        ajax: {
                            url: $s.data('api'),
                            dataType: 'json',
                            delay: 250,
                            data: function(params){
                                return {
                                    q: params.term || '',
                                    restaurantId: getRestaurantId()
                                };
                            },
                            processResults: d => ({
                                results: d.map(x => ({
                                    id: x.id,
                                    text: x.text || x.name
                                }))
                            })
                        },
                        dropdownParent: $('body'),
                        minimumInputLength: 0,
                        width: '100%',
                        placeholder: placeholder,
                        allowClear: true
                    });

                    $s.on('select2:select', function(e){
                        var data = e.params && e.params.data;
                        if (data && data.id) {
                            var option = new Option(data.text, data.id, true, true);
                            $s.append(option).trigger('change.select2');
                        }
                    });

                    if (existingValue) {
                        var option = new Option(existingText, existingValue, true, true);
                        $s.append(option).trigger('change.select2');
                    }
                }

                function updateItemControls(){
                    var hasRestaurant = !!getSelectedRestaurantId();
                    $('#add-item').prop('disabled', !hasRestaurant);
                }

                function markFieldValidity($field, isValid){
                    $field.toggleClass('input-error', !isValid);
                    var $error = $field.next('.field-error');
                    if (!isValid) {
                        if (!$error.length) {
                            $field.after('<span class="field-error">Obavezno polje ili količina mora biti veća od 0.</span>');
                        }
                    } else {
                        $error.remove();
                    }
                }

                function validateOrderRow($row){
                    var $menu = $row.find('select[name$=".MenuItemId"]');
                    var $qty = $row.find('input[name$=".Quantity"]');
                    var menuValid = !!$menu.val();
                    var qtyVal = parseInt($qty.val() || '0', 10);
                    var qtyValid = qtyVal > 0;
                    markFieldValidity($menu, menuValid);
                    markFieldValidity($qty, qtyValid);
                    return menuValid && qtyValid;
                }

                function bindRowValidation($row){
                    $row.find('select[name$=".MenuItemId"]').on('change', function(){
                        validateOrderRow($row);
                    });
                    $row.find('input[name$=".Quantity"]').on('blur', function(){
                        validateOrderRow($row);
                    });
                }

                function reindexRows(){
                    $('#order-items tbody tr').not('.order-item-row').each(function(index){
                        $(this).find('select[name$=".MenuItemId"]').attr('name', 'Items[' + index + '].MenuItemId');
                        $(this).find('input[name$=".Quantity"]').attr('name', 'Items[' + index + '].Quantity');
                        $(this).find('input[name$=".SpecialRequests"]').attr('name', 'Items[' + index + '].SpecialRequests');
                    });
                    idx = $('#order-items tbody tr').not('.order-item-row').length;
                }

                function animateRowIn($row){
                    $row.addClass('new-row');
                    requestAnimationFrame(function(){
                        $row.addClass('animate-in');
                    });
                }

                function animateRowOut($row){
                    $row.addClass('removing');
                    window.setTimeout(function(){
                        $row.remove();
                        reindexRows();
                    }, 240);
                }

                function addRow(){
                    var $template = $('.order-item-row').clone().removeClass('order-item-row').show();
                    $template.find('.select2-container').remove();
                    $template.find('select').removeClass('select2-hidden-accessible').removeAttr('data-select2-id aria-hidden tabindex');
                    var html = $template.html().replace(/__index__/g, idx);
                    var $tr = $('<tr></tr>').html(html).addClass('new-row');
                    $('#order-items tbody').append($tr);
                    $tr.find('.autocomplete-select').each(function(){
                        initMenuItemSelect($(this));
                    });
                    bindRowValidation($tr);
                    requestAnimationFrame(function(){
                        $tr.addClass('animate-in');
                    });
                    idx++;
                }

                // initialize existing selects
                $('#order-items tbody tr:not(.order-item-row) .autocomplete-select').each(function(){
                    var $s = $(this);
                    setTimeout(function(){
                        initMenuItemSelect($s);
                    }, 0);
                });

                // bind validation for rows already on the page
                $('#order-items tbody tr').not('.order-item-row').each(function(){
                    bindRowValidation($(this));
                });

                $('#restaurant-autocomplete').on('change', function(){
                    $('#order-items tbody tr').not('.order-item-row').remove();
                    reindexRows();
                    addRow();
                    updateItemControls();
                });

                $('#add-item').on('click', function(){ addRow(); });
                $(document).on('click', '.remove-item', function(){
                    var $row = $(this).closest('tr');
                    animateRowOut($row);
                });

                if ($('#order-items tbody tr').not('.order-item-row').length === 0) {
                    addRow();
                }

                // form validation on submit
                $('.order-form').on('submit', function(e){
                    var valid = true;
                    var $rows = $('#order-items tbody tr').not('.order-item-row');
                    if ($rows.length === 0) {
                        alert('Dodaj barem jednu stavku u narudžbu.');
                        valid = false;
                    }
                    $rows.each(function(){
                        var menu = $(this).find('select[name$=".MenuItemId"]').val();
                        var qty = parseInt($(this).find('input[name$=".Quantity"]').val() || '0');
                        if (!menu || menu === '' || qty <= 0) {
                            validateOrderRow($(this));
                            valid = false;
                            return false;
                        }
                    });

                    if (!valid) {
                        e.preventDefault();
                        return false;
                    }

                    // disable submit and show spinner
                    var $btn = $(this).find('button[type=submit]');
                    $btn.prop('disabled', true).data('orig', $btn.text()).text('Spremanje...');
                    return true;
                });
            });
        })(jQuery);
    </script>
}
