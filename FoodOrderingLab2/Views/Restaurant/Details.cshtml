@model FoodOrderingLab2.ViewModels.RestaurantDetailViewModel
@{ ViewData["Title"] = Model.Restaurant.Name; }

<section class="detail-page">
    <div class="detail-card detail-surface">
        <div class="detail-hero">
            <div>
                <span class="detail-eyebrow">Restaurant</span>
                <h1>@Model.Restaurant.Name</h1>
                <p class="detail-lead">@Model.Restaurant.Address</p>
            </div>
            <div class="price-panel">
                <span>Rating</span>
                <strong>@Model.Restaurant.Rating / 5</strong>
                <small>Open @Model.Restaurant.OpeningHours</small>
            </div>
        </div>

        <div class="contact-grid detail-section">
            <div class="contact-card"><span>Email</span><strong><a href="mailto:@Model.Restaurant.Email">@Model.Restaurant.Email</a></strong></div>
            <div class="contact-card"><span>Phone</span><strong><a href="tel:@Model.Restaurant.Phone">@Model.Restaurant.Phone</a></strong></div>
            <div class="contact-card"><span>Address</span><strong>@Model.Restaurant.Address</strong></div>
            <div class="contact-card"><span>Opening hours</span><strong>@Model.Restaurant.OpeningHours</strong></div>
        </div>

        <div class="detail-section">
            <div class="section-heading">
                <div>
                    <span class="detail-eyebrow">Explore the menu</span>
                    <h2>Menu Items</h2>
                </div>
                <span class="item-count">@Model.MenuItems.Count items</span>
            </div>
            <div class="detail-grid-2">
                @foreach (var item in Model.MenuItems)
                {
                    <div class="detail-mini-card">
                        <span class="card-kicker">@item.Category</span>
                        <h4>@item.Name</h4>
                        <p class="menu-item-description" title="@item.Description">@item.Description</p>
                        <div class="card-stat-row"><span>Price</span><strong>@item.Price.ToString("F2") EUR</strong></div>
                        <div class="card-stat-row"><span>Calories</span><strong>@item.Calories kcal</strong></div>
                        <a class="btn btn-outline" asp-controller="MenuItem" asp-action="Details" asp-route-id="@item.MenuItemId">View details</a>
                    </div>
                }
            </div>
        </div>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
        }

        <div class="detail-action action-bar">
            <a class="btn btn-secondary" asp-controller="Restaurant" asp-action="Index">Back to restaurants</a>
            <div class="action-bar-right">
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <a class="btn btn-outline" asp-controller="Restaurant" asp-action="Edit" asp-route-id="@Model.Restaurant.RestaurantId">Edit</a>
                }
                @if (User.IsInRole("Admin"))
                {
                    <form asp-controller="Restaurant" asp-action="Delete" asp-route-id="@Model.Restaurant.RestaurantId" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Jeste li sigurni da želite obrisati ovaj restoran?');">Delete</button>
                    </form>
                }
            </div>
        </div>
    </div>
</section>
