@model FoodOrderingLab2.ViewModels.RestaurantCreateViewModel
@using System.Linq
@using FoodOrderingLab2.Models.Enums
@{
    ViewData["Title"] = "Novi restoran";
    var categoryOptions = Enum.GetValues(typeof(FoodCategory)).Cast<FoodCategory>().ToList();
}

<div class="page-header page-header-center">
    <h1>Dodaj novi restoran</h1>
</div>

<div class="form-container">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Address"></label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Phone"></label>
            <input asp-for="Phone" class="form-control" placeholder="+385 1 123 4567" />
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Rating"></label>
            <input asp-for="Rating" class="form-control" type="number" step="0.1" min="0" max="5" />
            <span asp-validation-for="Rating" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="OpeningHours"></label>
            <input asp-for="OpeningHours" class="form-control" placeholder="09:00 - 22:00" />
            <span asp-validation-for="OpeningHours" class="text-danger"></span>
        </div>

        <div class="menu-items-section">
            <div class="menu-items-heading">
                <div>
                    <span class="detail-eyebrow">Restaurant menu</span>
                    <h3>Menu items</h3>
                </div>
            </div>
            <p class="form-help">Dodaj barem jedno jelo. Cijena mora biti veća od 0, a kalorije ne mogu biti negativne.</p>
            <span asp-validation-for="MenuItems" class="text-danger"></span>
            <div class="table-scroll">
            <table id="menu-items" class="menu-items-table">
                <thead>
                    <tr>
                        <th><span class="table-label">Name</span></th>
                        <th><span class="table-label">Description</span></th>
                        <th><span class="table-label">Category</span></th>
                        <th><span class="table-label">Price</span></th>
                        <th><span class="table-label">Calories</span></th>
                        <th><span class="table-label">Available</span></th>
                        <th><span class="table-label">Action</span></th>
                    </tr>
                </thead>
                <tbody>
                @for (int i = 0; i < Model.MenuItems.Count; i++)
                {
                    <tr>
                        <td><input class="form-control" name="MenuItems[@i].Name" value="@Model.MenuItems[i].Name" required maxlength="150" /></td>
                        <td><input class="form-control" name="MenuItems[@i].Description" value="@Model.MenuItems[i].Description" required maxlength="1000" /></td>
                        <td>
                            <select class="form-control" name="MenuItems[@i].Category">
                                @foreach (var category in categoryOptions)
                                {
                                    <option value="@category" selected="@(Model.MenuItems[i].Category == category ? "selected" : null)">@category</option>
                                }
                            </select>
                        </td>
                        <td><input class="form-control" name="MenuItems[@i].Price" type="number" step="0.01" min="0.01" max="9999.99" value="@Model.MenuItems[i].Price" required /></td>
                        <td><input class="form-control" name="MenuItems[@i].Calories" type="number" min="0" max="10000" value="@Model.MenuItems[i].Calories" required /></td>
                        <td><label class="availability-toggle"><input type="checkbox" name="MenuItems[@i].IsAvailable" value="true" @(Model.MenuItems[i].IsAvailable ? "checked" : "") /><span>Yes</span></label></td>
                        <td><button type="button" class="btn btn-danger btn-small remove-menu-item">Ukloni</button></td>
                    </tr>
                }

                <tr class="menu-item-row" style="display:none;">
                    <td><input class="form-control" name="MenuItems[__index__].Name" required maxlength="150" /></td>
                    <td><input class="form-control" name="MenuItems[__index__].Description" required maxlength="1000" /></td>
                    <td>
                        <select class="form-control" name="MenuItems[__index__].Category">
                            @foreach (var category in categoryOptions)
                            {
                                <option value="@category">@category</option>
                            }
                        </select>
                    </td>
                    <td><input class="form-control" name="MenuItems[__index__].Price" type="number" step="0.01" min="0.01" max="9999.99" required /></td>
                    <td><input class="form-control" name="MenuItems[__index__].Calories" type="number" min="0" max="10000" required /></td>
                    <td><label class="availability-toggle"><input type="checkbox" name="MenuItems[__index__].IsAvailable" value="true" checked /><span>Yes</span></label></td>
                    <td><button type="button" class="btn btn-danger btn-small remove-menu-item">Ukloni</button></td>
                </tr>
                    </tbody>
            </table>
            </div>

            <div class="menu-item-actions">
                <button type="button" id="add-menu-item" class="btn btn-secondary">Dodaj stavku</button>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Spremi restoran</button>
            <a asp-action="Index" class="btn btn-secondary">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        (function($){
            $(function(){
                var index = @Model.MenuItems.Count;

                function animateRowIn($row) {
                    $row.addClass('new-row');
                    requestAnimationFrame(function(){
                        $row.addClass('animate-in');
                    });
                }

                function animateRowOut($row) {
                    $row.addClass('removing');
                    window.setTimeout(function(){
                        $row.remove();
                    }, 240);
                }

                function addRow() {
                    var $template = $('.menu-item-row').clone().removeClass('menu-item-row').show();
                    var html = $template.html().replace(/__index__/g, index);
                    var $row = $('<tr></tr>').html(html).addClass('new-row');
                    $('#menu-items tbody').append($row);
                    requestAnimationFrame(function(){
                        $row.addClass('animate-in');
                    });
                    index++;
                }

                $('#add-menu-item').on('click', function(){
                    addRow();
                });

                $(document).on('click', '.remove-menu-item', function(){
                    var $row = $(this).closest('tr');
                    animateRowOut($row);
                });

                if ($('#menu-items tbody tr').length <= 1) {
                    addRow();
                }
            });
        })(jQuery);
    </script>
}
