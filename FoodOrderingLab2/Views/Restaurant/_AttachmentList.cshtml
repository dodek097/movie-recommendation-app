@model IReadOnlyCollection<FoodOrderingLab2.Models.RestaurantAttachment>

@if (Model.Count == 0)
{
    <p class="color-text-light">Nema uploadanih datoteka.</p>
}
else
{
    <table class="table">
        <thead>
            <tr><th>Datoteka</th><th>Veličina</th><th>Dodano</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var attachment in Model)
        {
            <tr>
                <td><a href="@attachment.FilePath" target="_blank" rel="noopener">@attachment.FileName</a></td>
                <td>@($"{attachment.FileSize / 1024.0:F1} KB")</td>
                <td>@attachment.CreatedAt.ToLocalTime().ToString("d.M.yyyy H:mm")</td>
                <td><button type="button" class="btn btn-danger btn-small delete-attachment" data-id="@attachment.RestaurantAttachmentId">Obriši</button></td>
            </tr>
        }
        </tbody>
    </table>
}
