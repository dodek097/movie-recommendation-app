@model FoodOrderingLab2.ViewModels.MenuItemDetailViewModel
@{ ViewData["Title"] = Model.MenuItem.Name; }
<section class="detail-page">
    <div class="card detail-card">
        <div class="detail-card-header">
            <div>
                <span class="detail-subtitle">Menu item</span>
                <h1>@Model.MenuItem.Name</h1>
            </div>
            <div class="detail-meta">
                <span>Price: <strong>@Model.MenuItem.Price.ToString("F2")</strong></span>
                <span>Calories: <strong>@Model.MenuItem.Calories</strong></span>
            </div>
        </div>

        <div class="detail-section">
            <h2>Description</h2>
            <p>@Model.MenuItem.Description</p>
        </div>

        <div class="detail-section">
            <h2>Restaurant</h2>
            <p class="detail-subtitle">@Model.Restaurant?.Name</p>
            <p>@Model.Restaurant?.Address</p>
        </div>

        <div class="detail-action">
            <a class="btn btn-secondary" asp-controller="MenuItem" asp-action="Index">Back to menu</a>
            <a class="btn btn-secondary" asp-controller="MenuItem" asp-action="Edit" asp-route-id="@Model.MenuItem.MenuItemId">Edit</a>
            <form asp-controller="MenuItem" asp-action="Delete" asp-route-id="@Model.MenuItem.MenuItemId" method="post" class="d-inline-block" onsubmit="return confirm('Jeste li sigurni da želite obrisati stavku menija?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>
</section>
