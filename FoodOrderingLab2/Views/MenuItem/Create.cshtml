@model FoodOrderingLab2.ViewModels.MenuItemCreateViewModel
@using FoodOrderingLab2.Models.Enums
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Dodaj stavku menija";
    var restaurants = ViewBag.Restaurants as List<FoodOrderingLab2.Models.Restaurant> ?? new List<FoodOrderingLab2.Models.Restaurant>();
}

<div class="page-header page-header-center">
    <h1>Dodaj stavku menija</h1>
</div>

<div class="form-container">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="form-group">
            <label asp-for="RestaurantId"></label>
            <select asp-for="RestaurantId" class="form-control" asp-items='new SelectList(restaurants, "RestaurantId", "Name")'>
                <option value="">Odaberi restoran</option>
            </select>
            <span asp-validation-for="RestaurantId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Category"></label>
            <select asp-for="Category" class="form-control">
                @foreach (var category in Enum.GetValues(typeof(FoodCategory)).Cast<FoodCategory>())
                {
                    <option value="@category" selected="@(Model.Category == category ? "selected" : null)">@category</option>
                }
            </select>
            <span asp-validation-for="Category" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Price"></label>
            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" max="9999.99" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Calories"></label>
            <input asp-for="Calories" class="form-control" type="number" min="0" max="10000" />
            <span asp-validation-for="Calories" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="checkbox-label">
                <input asp-for="IsAvailable" type="checkbox" />
                <span>Dostupno za naručivanje</span>
            </label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Spremi menu item</button>
            <a asp-action="Index" class="btn btn-secondary">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
