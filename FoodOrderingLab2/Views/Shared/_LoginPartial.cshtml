@using Microsoft.AspNetCore.Identity
@inject SignInManager<FoodOrderingLab2.Models.AppUser> SignInManager
@inject UserManager<FoodOrderingLab2.Models.AppUser> UserManager

<ul class="nav-list auth-links">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item"><span class="nav-link">@User.Identity?.Name</span></li>
    @if (!User.IsInRole("Admin") && !User.IsInRole("Manager"))
    {
        <li class="nav-item"><a class="nav-link" asp-controller="Customer" asp-action="MyProfile">My Profile</a></li>
    }
    <li class="nav-item">
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
            <button type="submit" class="nav-link nav-button">Odjava</button>
        </form>
    </li>
}
else
{
    <li class="nav-item"><a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Registracija</a></li>
    <li class="nav-item"><a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Prijava</a></li>
}
</ul>
