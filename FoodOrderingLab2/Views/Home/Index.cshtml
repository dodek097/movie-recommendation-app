@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="text-center mt-lg mb-lg">
    <h1>Welcome to FoodOrder</h1>
    <p class="color-text-light" style="font-size: 1.1rem; margin-bottom: var(--spacing-lg);">
        Discover amazing restaurants and delicious food, all in one place.
    </p>
</section>

<!-- Quick Actions Grid -->
<div class="grid grid-cols-3 mb-lg" style="justify-items: center;">
    <!-- Restaurants Card -->
    <div class="card" style="text-align: center;">
        <div class="card-header">
            <h3 class="card-title">Explore Restaurants</h3>
        </div>
        <div class="card-body">
            <p class="card-description">Browse thousands of restaurants and find your next favorite place to eat.</p>
        </div>
        <div class="card-footer">
            <a asp-controller="Restaurant" asp-action="Index" class="btn btn-primary" style="width: 100%;">
                View Restaurants
            </a>
        </div>
    </div>

    <!-- Menu Items Card -->
    <div class="card" style="text-align: center;">
        <div class="card-header">
            <h3 class="card-title">Browse Menu</h3>
        </div>
        <div class="card-body">
            <p class="card-description">Discover delicious food items from your favorite restaurants worldwide.</p>
        </div>
        <div class="card-footer">
            <a asp-controller="MenuItem" asp-action="Index" class="btn btn-primary" style="width: 100%;">
                View Menu Items
            </a>
        </div>
    </div>

    <!-- Orders Card -->
    <div class="card" style="text-align: center;">
        <div class="card-header">
            <h3 class="card-title">My Orders</h3>
        </div>
        <div class="card-body">
            <p class="card-description">Track your orders and manage your food delivery history.</p>
        </div>
        <div class="card-footer">
            <a asp-controller="Order" asp-action="Index" class="btn btn-primary" style="width: 100%;">
                View Orders
            </a>
        </div>
    </div>
</div>

<!-- Featured Section -->
<section class="text-center mt-xl mb-lg">
    <h2>Featured Features</h2>
    <p class="color-text-light" style="margin-bottom: var(--spacing-lg);">
        Everything you need to enjoy great food delivered fast.
    </p>
</section>

<!-- Features Grid -->
<div class="grid grid-cols-3 mb-lg">
    <div class="card">
        <h4 class="text-center">Fast Delivery</h4>
        <p class="text-center color-text-light">Get your food delivered quickly to your doorstep.</p>
    </div>
    <div class="card">
        <h4 class="text-center">Fresh Food</h4>
        <p class="text-center color-text-light">Quality ingredients prepared by expert chefs.</p>
    </div>
    <div class="card">
        <h4 class="text-center">Secure Ordering</h4>
        <p class="text-center color-text-light">Your payment and personal info are always safe.</p>
    </div>
</div>

<!-- Call to Action -->
<section class="text-center mt-xl mb-xl" style="background-color: var(--color-secondary); padding: var(--spacing-lg); border-radius: var(--border-radius); border: 1px solid var(--color-border);">
    <h2>Ready to Order?</h2>
    <p class="color-text-light mb-lg">Start exploring restaurants and place your first order today!</p>
    <a asp-controller="Restaurant" asp-action="Index" class="btn btn-primary btn-large">
        Get Started
    </a>
</section>





