@model FoodOrderingLab2.ViewModels.CustomerProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="page-header page-header-center">
    <h1>My Profile</h1>
    <p>Update the contact information used for your orders.</p>
</div>

<div class="form-container identity-form">
    <form asp-action="MyProfile" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="form-group">
            <label>Email</label>
            <input class="form-control" value="@ViewBag.Email" disabled />
            <p class="form-help">Email belongs to your login account and cannot be changed here.</p>
        </div>

        <div class="form-group">
            <label asp-for="FirstName"></label>
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="LastName"></label>
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Phone"></label>
            <input asp-for="Phone" class="form-control" placeholder="+385 91 123 4567" />
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Address"></label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Profile</button>
            <a asp-controller="Order" asp-action="Index" class="btn btn-secondary">Back to Orders</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
