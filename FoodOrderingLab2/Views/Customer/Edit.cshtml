@model FoodOrderingLab2.ViewModels.CustomerCreateViewModel
@{
    ViewData["Title"] = "Uredi kupca";
    var customerId = ViewBag.CustomerId as int? ?? 0;
}

<div class="page-header page-header-center">
    <h1>Uredi kupca</h1>
</div>

<div class="form-container">
    <form asp-action="Edit" asp-route-id="@customerId" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="form-group">
            <label asp-for="FirstName"></label>
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="LastName"></label>
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Phone"></label>
            <input asp-for="Phone" class="form-control" placeholder="+385 91 123 4567" />
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Address"></label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label for="register-date">Datum registracije</label>
            @{ ViewData["name"] = "RegisterDate"; ViewData["date"] = Model.RegisterDate; }
            <partial name="_DateTimePartial" />
            <span asp-validation-for="RegisterDate" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Spremi promjene</button>
            <a asp-action="Details" asp-route-id="@customerId" class="btn btn-secondary">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
