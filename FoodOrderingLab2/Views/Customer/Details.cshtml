@model FoodOrderingLab2.Models.Customer
@{ ViewData["Title"] = Model.FullName; }

<section class="detail-page">
    <div class="detail-card detail-surface">
        <div class="detail-hero">
            <div>
                <span class="detail-eyebrow">Customer profile</span>
                <h1>@Model.FullName</h1>
                <p class="detail-lead">@Model.Address</p>
            </div>
            <div class="price-panel">
                <span>Customer since</span>
                <strong>@Model.RegisterDate.ToString("MMM yyyy")</strong>
                <small>@Model.Orders.Count total orders</small>
            </div>
        </div>

        <div class="contact-grid detail-section">
            <div class="contact-card">
                <span>Email</span>
                <strong><a href="mailto:@Model.Email">@Model.Email</a></strong>
            </div>
            <div class="contact-card">
                <span>Phone</span>
                <strong><a href="tel:@Model.Phone">@Model.Phone</a></strong>
            </div>
            <div class="contact-card">
                <span>Address</span>
                <strong>@Model.Address</strong>
            </div>
            <div class="contact-card">
                <span>Registered</span>
                <strong>@Model.RegisterDate.ToString("MMM dd, yyyy")</strong>
            </div>
        </div>

        <div class="detail-section">
            <div class="section-heading">
                <div>
                    <span class="detail-eyebrow">Order history</span>
                    <h2>Orders</h2>
                </div>
                <span class="item-count">@Model.Orders.Count orders</span>
            </div>

            @if (Model.Orders.Count > 0)
            {
                <div class="order-item-list">
                    @foreach (var order in Model.Orders)
                    {
                        <div class="order-detail-item">
                            <div>
                                <strong>Order #@order.OrderId</strong>
                                <small>@order.OrderDate.ToString("MMM dd, yyyy 'at' HH:mm")</small>
                            </div>
                            <span class="status-badge">@order.Status</span>
                            <div>
                                <strong>@order.TotalPrice.ToString("F2") EUR</strong>
                                <a class="btn btn-outline btn-small" asp-controller="Order" asp-action="Details" asp-route-id="@order.OrderId">View details</a>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="attachment-empty-state">
                    <strong>No orders yet</strong>
                    <p>This customer has not placed an order.</p>
                </div>
            }
        </div>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
        }

        <div class="detail-action action-bar">
            <a class="btn btn-secondary" asp-controller="Customer" asp-action="Index">Back to customers</a>
            <div class="action-bar-right">
                <a class="btn btn-outline" asp-controller="Customer" asp-action="Edit" asp-route-id="@Model.CustomerId">Edit</a>
                @if (User.IsInRole("Admin"))
                {
                    <form asp-controller="Customer" asp-action="Delete" asp-route-id="@Model.CustomerId" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Jeste li sigurni da želite obrisati ovog kupca?');">Delete</button>
                    </form>
                }
            </div>
        </div>
    </div>
</section>
