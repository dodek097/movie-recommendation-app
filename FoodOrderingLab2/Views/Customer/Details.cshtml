@model FoodOrderingLab2.Models.Customer
@{ ViewData["Title"] = Model.FullName; }
<section class="detail-page">
    <div class="card detail-card">
        <div class="detail-card-header">
            <div>
                <span class="detail-subtitle">Customer profile</span>
                <h1>@Model.FullName</h1>
            </div>
            <div class="detail-meta">
                <span>Email: <strong>@Model.Email</strong></span>
                <span>Phone: <strong>@Model.Phone</strong></span>
            </div>
        </div>

        <div class="detail-section">
            <h2>Contact</h2>
            <p>@Model.Address</p>
            <p>Member since: <strong>@Model.RegisterDate.ToString("MMM dd, yyyy")</strong></p>
        </div>

        <div class="detail-section">
            <h2>Orders</h2>
            @if (Model?.Orders?.Count > 0)
            {
                <ul class="detail-list">
                    @foreach (var order in Model.Orders)
                    {
                        <li>
                            <strong>Order #@order.OrderId</strong> - @order.Status - @order.TotalPrice.ToString("F2")
                            <br />
                            <a class="btn btn-outline btn-small" asp-controller="Order" asp-action="Details" asp-route-id="@order.OrderId">View details</a>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p>No orders yet.</p>
            }
        </div>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
        }

        <div class="detail-action">
            <a class="btn btn-secondary" asp-controller="Customer" asp-action="Index">Back to customers</a>
            <a class="btn btn-outline" asp-controller="Customer" asp-action="Edit" asp-route-id="@Model.CustomerId">Edit</a>
            <form asp-controller="Customer" asp-action="Delete" asp-route-id="@Model.CustomerId" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger" onclick="return confirm('Jeste li sigurni da želite obrisati ovog kupca?');">Delete</button>
            </form>
        </div>
    </div>
</section>
